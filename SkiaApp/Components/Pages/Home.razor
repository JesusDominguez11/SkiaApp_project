@page "/"
@using SkiaApp.Services

<PageTitle>SkiaApp</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-8 mb-8 page-transition">
    <MudItem xs="12">
        <MudPaper Elevation="4" Class="pa-6 paper-gradient" Style="border-radius:10px;">
            <MudText Typo="Typo.h4" Class="mb-2">
                SkiaApp
            </MudText>

            <MudText Typo="Typo.subtitle1" Color="Color.Primary">
                
            </MudText>
        </MudPaper>
    </MudItem>

    <MudStack Spacing="0" Class="mt-6">
        <MudText Typo="Typo.button" Class="paper-title">
            INFORMACION
        </MudText>
        <MudPaper class="paper-gradient" >
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <b>Versión instalada:</b>
                    @_currentVersion
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <b>Estado:</b>
                @_updateStatus
            </MudStack>
        </MudPaper>
    </MudStack>

    <MudStack Spacing="0" Class="mt-6">
        <MudText Typo="Typo.button" Class="paper-title">
            ACCIONES RAPIDAS
        </MudText>
        <MudPaper Class="paper-gradient">
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                Buscar actualizaciones
                <MudButton Variant="Variant.Text"
                           Color="Color.Dark"
                           OnClick="CheckForUpdatesAsync">
                    <MudIcon Icon="@Icons.Material.Outlined.SystemUpdate"/>
                       </MudButton>
            </MudStack>

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                Galeria
                <MudButton Variant="Variant.Text"
                           Color="Color.Dark"
                           Href="/drawings">
                    <MudIcon Icon="@Icons.Material.Outlined.ArrowRight" />
                </MudButton>
            </MudStack>

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                Configuracion
                <MudButton Variant="Variant.Text"
                           Color="Color.Dark"
                           Href="/settings">
                    <MudIcon Icon="@Icons.Material.Outlined.ArrowRight" />
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@if (_updateInfo != null)
{
    <UpdateDialog 
    Update="_updateInfo"
    OnClosed="UpdateClosed" />
}

@code
{
    bool showmodal = false;
    private string _currentVersion = "";
    private string _updateStatus = "Comprobando...";
    private bool _updateDismissed;

    protected override async Task OnInitializedAsync()
    {
        _currentVersion = VersionService.CurrentVersion;

        await CheckForUpdatesAsync();
    }

    private UpdateInfo? _updateInfo;

    private async Task CheckForUpdatesAsync()
    {
        if (_updateDismissed)
            return;

        _updateStatus = "Comprobando...";

        StateHasChanged();

        var update = await UpdateService.CheckForUpdatesAsync();

        if (update == null)
        {
            _updateStatus = "La aplicación está actualizada";
            return;
        }

        _updateStatus = $"Disponible {update.Version}";

        _updateInfo = update;

        Console.WriteLine($"UPDATE ENCONTRADA: {update.Version}");

        StateHasChanged();
    }

    private void UpdateClosed(bool dismissed)
    {
        _updateDismissed = dismissed;

        _updateInfo = null;

        StateHasChanged();
    }
}