
@if (Update != null)
{
    <div class="modal-overlay">
        <div class="modal-contenido" Style="margin:5vh; animation: fadeInUp .6s ease;">
            <MudContainer>
                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h5">
                        Nueva actualización disponible
                    </MudText>
                    <MudText Typo="Typo.subtitle1"
                             Color="Color.Primary">
                        Versión @Update.Version
                    </MudText>
                    <MudProgressLinear Value="@(_progress * 100)"
                                       Color="Color.Primary"
                                       Rounded="true"
                                       Class="update-progress"
                                       Style="height:10px;" />
                    <MudText Typo="Typo.body2">
                        @_status
                    </MudText>
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Default"
                                   Disabled="@_isUpdating"
                                   OnClick="Close"
                                    EndIcon="@Icons.Material.Outlined.WatchLater">
                            <MudText>Más tarde</MudText>
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Dark"
                                   Disabled="@_isUpdating"
                                   OnClick="StartUpdate"
                        EndIcon="@Icons.Material.Outlined.Update">
                                   <MudText>
                                    Actualizar
                                   </MudText>
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudContainer>
        </div>
    </div>
}


@code {

    [Parameter]
    public UpdateInfo Update { get; set; } = default!;
    private bool _isUpdating;
    private double _progress;
    private string _status = "Nueva actualización disponible";
    [Parameter]
    public EventCallback<bool> OnClosed { get; set; }

    private void Close()
    {
        if (_isUpdating)
            return;

        OnClosed.InvokeAsync(true);
    }



    private async Task StartUpdate()
    {
        _isUpdating = true;


        _status =
            "Descargando actualización...";


        StateHasChanged();



        var progress =
            new Progress<DownloadProgress>(p =>
            {
                InvokeAsync(() =>
                {
                    _progress = p.Percentage;


                    _status =
                        $"Descargando {p.Percentage:P0}";


                    StateHasChanged();

                });

            });



        var path =
            await DownloadService.DownloadFileAsync(
                Update.ApkUrl,
                progress);



        if (path == null)
        {
            _status =
                "Error descargando actualización";


            _isUpdating = false;


            StateHasChanged();

            return;
        }



        _status =
            "Instalando actualización...";


        StateHasChanged();



        await InstallerService.InstallAsync(path);
    }

}